# ── Aletheia / VerifAI — Environment Variables ──
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Flask secret key — REQUIRED in production
# Generate with: python -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Hugging Face API token for BERT inference
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Admin token for /logs endpoint access
# Generate any random string
ADMIN_TOKEN=

# Port (Render sets this automatically)
PORT=10000
